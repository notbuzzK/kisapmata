{
  "expo": {
    "name": "kisapmata",
    "slug": "kisapmata",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/icon.png",
    "scheme": "kisapmata",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "bundler": "metro",
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.notbuzz.kisapmata"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "LANDSCAPE_RIGHT"
        }
      ],
      [
        "expo-navigation-bar",
        {
          "enforceContrast": true,
          "barStyle": "light",
          "visibility": "visible"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Kisapmata to access your camera",
          "microphonePermission": "Allow Kisapmata to access your microphone",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ],
      [
      "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "expo-navigation-bar": {
        "enforceContrast": true,
        "barStyle": "light",
        "visibility": "visible"
      },
      "eas": {
        "projectId": "77562dd4-5d60-4666-b727-d6d2b7ebe06e"
      }
    }
  }
}
